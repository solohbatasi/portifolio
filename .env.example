# Required for production canonical URLs, robots.txt and sitemap.xml.
VITE_PUBLIC_SITE_URL=

# Use / for a root domain or /portfolio/ for a subdirectory deployment.
VITE_BASE_PATH=/

# Server-only Kadi configuration. Never prefix the secret key with VITE_.
KADI_BASE_URL=https://kadi.pulsetikafrica.com
KADI_SECRET_KEY=
COFFEE_MIN_AMOUNT=10
COFFEE_MAX_AMOUNT=10000
COFFEE_FRONTEND_URL=

# Optional absolute server-writable directory outside public_html.
COFFEE_RATE_LIMIT_DIR=
